{
  "entities": {
    "UserAccount": {
      "title": "UserAccount",
      "description": "User accounts with roles",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "user"] },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["username", "role", "displayName"]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "Engineering quotation contract draft and details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "customerName"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "Quick appointment event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["visit", "measure", "remeasure", "other"] },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "remarks": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["id", "title", "type", "date", "time", "createdBy", "createdAt", "updatedAt"]
    },
    "SharedCategories": {
      "title": "SharedCategories",
      "description": "Global shared list of engineering categories",
      "type": "object",
      "properties": {
        "list": { "type": "array" }
      },
      "required": ["list"]
    },
    "SharedLibrary": {
      "title": "SharedLibrary",
      "description": "Global shared standard items library",
      "type": "object",
      "properties": {
        "data": { "type": "object" },
        "categoryOrder": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["data", "categoryOrder"]
    },
    "SharedSettings": {
      "title": "SharedSettings",
      "description": "Global shared quote settings",
      "type": "object",
      "properties": {
        "bankName": { "type": "string" },
        "companyName": { "type": "string" },
        "bankAccount": { "type": "string" },
        "fpsId": { "type": "string" },
        "defaultTerms": { "type": "string" }
      }
    },
    "ProjectTemplate": {
      "title": "ProjectTemplate",
      "description": "Predefined project category and item templates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "items": { "type": "array" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["id", "name", "items", "createdBy", "createdAt", "updatedAt"]
    },
    "DOrder": {
      "title": "DOrder",
      "description": "D-Order workflow stage and progress tracker",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNo": { "type": "string" },
        "address": { "type": "string" },
        "step1": { "type": "boolean" },
        "step2": { "type": "boolean" },
        "step3": { "type": "boolean" },
        "step4": { "type": "boolean" },
        "step5": { "type": "boolean" },
        "step6": { "type": "boolean" },
        "isCompleted": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["id", "orderNo", "address", "step1", "step2", "step3", "step4", "step5", "step6", "isCompleted", "createdBy", "createdAt", "updatedAt"]
    },
    "Backup": {
      "title": "Backup",
      "description": "System database state backup JSON document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "filename": { "type": "string" },
        "createdAt": { "type": "integer" },
        "dataJson": { "type": "string" },
        "size": { "type": "integer" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "filename", "createdAt", "dataJson", "size", "createdBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserAccount",
      "description": "Collection of platform user accounts"
    },
    "/quotations/{quoteId}": {
      "schema": "Quotation",
      "description": "Collection of all quotes and contracts"
    },
    "/calendar_events/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Collection of general appointment calendar events"
    },
    "/project_templates/{templateId}": {
      "schema": "ProjectTemplate",
      "description": "Collection of common project templates"
    },
    "/d_orders/{orderId}": {
      "schema": "DOrder",
      "description": "Collection of D-Order progress tracking stages"
    },
    "/backups/{backupId}": {
      "schema": "Backup",
      "description": "Collection of automated or manual database backup JSON files"
    },
    "/shared_data/categories": {
      "schema": "SharedCategories",
      "description": "Global shared categories list"
    },
    "/shared_data/library": {
      "schema": "SharedLibrary",
      "description": "Global shared standard item library"
    },
    "/shared_data/settings": {
      "schema": "SharedSettings",
      "description": "Global shared settings document"
    }
  }
}
